// Prisma schema for prode2026 — World Cup prediction pool.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PLAYER
}

enum UserStatus {
  PENDING
  APPROVED
}

enum MatchStatus {
  SCHEDULED
  FINISHED
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  name         String?
  // How much the player expects to pay for tournament entry, in ARS centavos
  // (e.g. 2_500_000 = $25.000,00). Stored as integer to avoid float rounding.
  entryBidCents Int?
  passwordHash String
  role         Role         @default(PLAYER)
  status       UserStatus   @default(PENDING)
  createdAt    DateTime     @default(now())
  predictions  Prediction[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Admin-written, funny recap of a finished match-day. Keyed by the Argentina
// day string (YYYY-MM-DD) so it lines up with dayKey().
model DaySummary {
  id        String   @id @default(cuid())
  dayKey    String   @unique
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Match {
  id          String       @id @default(cuid())
  homeTeam    String
  awayTeam    String
  kickoffAt   DateTime
  status      MatchStatus  @default(SCHEDULED)
  homeScore   Int?
  awayScore   Int?
  createdAt   DateTime     @default(now())
  predictions Prediction[]

  @@index([kickoffAt])
}

model Prediction {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   String
  homeScore Int
  awayScore Int
  points    Int?
  // True when the system filled in a 0-0 default because the player never
  // submitted a prediction before kickoff (applied at scoring time).
  auto      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
}
